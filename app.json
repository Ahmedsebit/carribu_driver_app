        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.carribu.driver",
      "permissions": [
        "ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "deedde0b-7d63-4f67-a26f-be7d15a5c7b6"
      }
    },
    "owner": "firstbodis-organization"
  }
}
